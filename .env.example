# PeopleSoft Financials (Oracle) database
#For getting the oracle DB server details, check the TNS file for the Environment eg. DEMO entry.
#Alternatively, you can use TNSPING to get the server details. on Windows CMD > Type TNSPING PS92DMO.
ORACLE_DSN=hostname:port/service_name
ORACLE_USER=your_username
ORACLE_PASSWORD=your_password

# Azure AI Foundry — Claude LLM (used by the /chat endpoint)
MICROSOFT_FOUNDRY_API_KEY=foundry_api_key
MICROSOFT_FOUNDRY_BASE_URL=https://your-resource.services.ai.azure.com
# Optional: override the default model (claude-sonnet-4-5)
# MICROSOFT_FOUNDRY_MODEL=claude-sonnet-4-5
